<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | The Intentional Tea</title>
    <meta name="description" content="{{ description }}">
    <meta property="og:title" content="{{ title }} | The Intentional Tea">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:image" content="/images/Logo_Main.png">
    <meta property="og:url" content="https://theintentionaltea.com{{ page.url }}">
    <meta property="og:type" content="article">
    <meta property="article:published_time" content="{{ date | isoDate }}">

    <link rel="icon" type="image/png" href="/images/favicon.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+Display:ital,wght@0,300;0,400;1,300;1,400&family=Instrument+Sans:wght@400;500;600&display=swap');

        body { background-color: #FAF7F2; color: #1a1a1a; font-family: 'Instrument Sans', sans-serif; }
        .playfair { font-family: 'Playfair Display', serif; font-style: italic; font-weight: 400; }
        .serif { font-family: 'Noto Serif Display', serif; font-weight: 300; letter-spacing: 0.03em; }
        .serif-regular { font-family: 'Noto Serif Display', serif; font-weight: 400; letter-spacing: 0.03em; }
        .ui-label { font-family: 'Instrument Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.35em; font-size: 10px; font-weight: 700; }
        .header-link { transition: color 0.3s ease; text-transform: uppercase; letter-spacing: 0.2em; font-size: 9px; font-weight: 700; color: #1a1a1a; }
        .header-link:hover { color: #E2C0B9; }
        #mobile-nav { display: none; flex-direction: column; }
        #mobile-nav.active { display: flex; }

        /* Post body styles */
        .post-body p { font-size: 0.9375rem; line-height: 1.85; color: #2a2a2a; margin-bottom: 1.4rem; font-weight: 300; }
        .post-body h2 { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.75rem; line-height: 1.3; color: #1a1a1a; margin-top: 2.5rem; margin-bottom: 1rem; font-weight: 400; }
        .post-body h3 { font-family: 'Instrument Sans', sans-serif; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.25em; font-weight: 700; color: #1a1a1a; margin-top: 2rem; margin-bottom: 0.75rem; }
        .post-body strong { font-weight: 600; color: #1a1a1a; }
        .post-body em { font-style: italic; }
        .post-body ul { list-style: none; padding: 0; margin-bottom: 1.4rem; }
        .post-body ul li { position: relative; padding-left: 1.25rem; margin-bottom: 0.5rem; font-size: 0.9375rem; color: #2a2a2a; font-weight: 300; }
        .post-body ul li::before { content: ''; position: absolute; left: 0; top: 0.6rem; width: 5px; height: 5px; background: #C99B92; transform: rotate(45deg); }
        .post-body ol { list-style: decimal; padding-left: 1.5rem; margin-bottom: 1.4rem; }
        .post-body ol li { font-size: 0.9375rem; color: #2a2a2a; font-weight: 300; margin-bottom: 0.5rem; }
        .post-body blockquote { border-left: 2px solid #C99B92; padding-left: 1.5rem; margin: 2rem 0; }
        .post-body blockquote p { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.1rem; color: #1a1a1a; font-weight: 400; }
        .post-body a { color: #1a1a1a; border-bottom: 1px solid rgba(26,26,26,0.25); transition: color 0.2s, border-color 0.2s; }
        .post-body a:hover { color: #C99B92; border-color: #C99B92; }
        .post-body hr { border: none; border-top: 1px solid rgba(26,26,26,0.1); margin: 2.5rem 0; }
    </style>
</head>
<body class="antialiased">

    <div class="w-full bg-[#E2C0B9] py-3 flex justify-center items-center" role="presentation">
        <p class="text-[10px] tracking-[0.2em] text-black/70 uppercase font-bold">Free digital stickers + 20% off — join our mailing list.</p>
    </div>

    <header class="sticky top-0 z-50 bg-[#FAF7F2]/95 backdrop-blur-md border-b border-black/15" role="banner">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="lg:hidden w-1/3">
                <button onclick="toggleMenu()" class="header-link flex items-center gap-2" aria-label="Toggle Menu">
                    <svg class="pointer-events-none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                    <span class="pointer-events-none" aria-hidden="true">Menu</span>
                </button>
            </div>
            <nav class="hidden lg:flex w-2/5 justify-start space-x-6" aria-label="Main navigation">
                <a href="/index.html" class="header-link">Home</a>
                <a href="/shop.html" class="header-link">Shop</a>
                <a href="/book.html" class="header-link">Work With Me</a>
                <a href="/about.html" class="header-link">About</a>
                <a href="/blog.html" class="header-link border-b border-black/20" style="color:#C99B92;">Blog</a>
                <a href="/social.html" class="header-link">Links</a>
            </nav>
            <div class="w-1/3 lg:w-1/5 flex justify-center">
                <a href="/index.html">
                    <img src="/images/Logo_Main.png" alt="The Intentional Tea Logo" class="h-8 md:h-12 w-auto object-contain">
                </a>
            </div>
            <div class="w-1/3 lg:w-2/5 flex justify-end">
                <a href="https://gumroad.com/cart" class="gumroad-scroll flex items-center space-x-2 group" aria-label="Cart">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-[#E2C0B9] transition-colors" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    <span class="header-link">Cart</span>
                </a>
            </div>
        </div>
        <nav id="mobile-nav" class="lg:hidden items-center space-y-4 pb-6 border-t border-black/5 pt-4 bg-[#FAF7F2]" aria-label="Mobile navigation">
            <a href="/index.html" class="header-link">Home</a>
            <a href="/shop.html" class="header-link">Shop</a>
            <a href="/book.html" class="header-link">Work With Me</a>
            <a href="/about.html" class="header-link">About</a>
            <a href="/blog.html" class="header-link" style="color:#C99B92;">Blog</a>
            <a href="/social.html" class="header-link">Links</a>
        </nav>
    </header>

    <main>
        <section class="bg-[#1a1a1a] py-20 px-6 text-center space-y-4">
            {% if category %}
            <span class="text-[9px] uppercase tracking-widest font-bold" style="color:#C99B92;">{{ category }}</span>
            {% endif %}
            <h1 class="playfair text-5xl md:text-6xl text-white leading-[1.1]">{{ title }}</h1>
            <p class="text-[10px] uppercase tracking-[0.4em] text-white/40">{{ date | postDate }}</p>
        </section>

        <article class="max-w-2xl mx-auto py-20 px-6 post-body">
            {{ content | safe }}
        </article>

        <section class="bg-[#E2C0B9] py-16 px-6">
            <div class="max-w-2xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
                <a href="/blog.html" class="text-[10px] uppercase tracking-[0.3em] font-bold text-[#1a1a1a] hover:text-white transition-colors">&larr; Back to the Blog</a>
                <a href="/shop.html" class="inline-block bg-[#1a1a1a] text-white px-10 py-4 text-[10px] uppercase tracking-[0.3em] font-bold hover:bg-white hover:text-black transition-all">Shop the Collection</a>
            </div>
        </section>
    </main>

    <footer class="bg-[#FAF7F2] py-4 px-6 border-t border-black/5" role="contentinfo">
        <div class="max-w-sm mx-auto flex flex-col items-center gap-3 text-[8px] uppercase tracking-[0.3em] text-[#1a1a1a]/60">
            <span class="text-[#1a1a1a]/70 font-semibold">&copy; 2026 The Intentional Tea</span>
        </div>
    </footer>

    <script src="https://gumroad.com/js/gumroad.js"></script>
    <script>
        function toggleMenu() {
            const nav = document.getElementById('mobile-nav');
            nav.classList.toggle('active');
        }
    </script>
</body>
</html>

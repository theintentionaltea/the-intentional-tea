---
permalink: /blog.html
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Blog | The Intentional Tea</title>
    <meta name="description" content="Strategy, perspective, and the occasional reframe. Essays on alignment and intentional living from The Intentional Tea.">
    <meta property="og:title" content="The Intentional Tea Blog">
    <meta property="og:description" content="Essays on alignment and soft authority.">
    <meta property="og:image" content="/images/Logo_Main.png">
    <meta property="og:url" content="https://theintentionaltea.com/blog.html">

    <link rel="icon" type="image/png" href="/images/favicon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://gumroad.com/js/gumroad.js"></script>
    <link rel="stylesheet" href="/style.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+Display:ital,wght@0,300;1,300&family=Instrument+Sans:wght@400;500;600&display=swap');

        body { background-color: #FAF7F2; color: #1a1a1a; font-family: 'Instrument Sans', sans-serif; }
        h1, h2, h3, h4, .serif { font-family: 'Noto Serif Display', serif; font-weight: 300; letter-spacing: 0.03em; }
        .playfair { font-family: 'Playfair Display', serif; font-style: italic; font-weight: 400; }
        .bg-rose { background-color: #E2C0B9; }
        .text-rose { color: #C99B92; }
        .header-link { transition: color 0.3s ease; text-transform: uppercase; letter-spacing: 0.2em; font-size: 9px; font-weight: 700; color: #1a1a1a; }
        .header-link:hover { color: #E2C0B9; }
        #mobile-nav { display: none; flex-direction: column; }
        #mobile-nav.active { display: flex; }
    </style>
</head>
<body class="antialiased">

    <div class="w-full bg-rose py-3 flex justify-center items-center" role="presentation">
        <p class="text-[10px] tracking-[0.2em] text-black/70 uppercase font-bold">Free digital stickers + 20% off — join our mailing list.</p>
    </div>

    <header class="sticky top-0 z-50 bg-[#FAF7F2]/95 backdrop-blur-md border-b border-black/15" role="banner">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="lg:hidden w-1/3">
                <button onclick="toggleMenu()" class="header-link flex items-center gap-2" aria-label="Toggle Menu">
                    <svg class="pointer-events-none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                    <span class="pointer-events-none" aria-hidden="true">Menu</span>
                </button>
            </div>
            <nav class="hidden lg:flex w-2/5 justify-start space-x-6" aria-label="Main navigation">
                <a href="/index.html" class="header-link">Home</a>
                <a href="/shop.html" class="header-link">Shop</a>
                <a href="/book.html" class="header-link">Work With Me</a>
                <a href="/about.html" class="header-link">About</a>
                <a href="/blog.html" class="header-link border-b border-black/20 text-rose">Blog</a>
                <a href="/social.html" class="header-link">Links</a>
            </nav>
            <div class="w-1/3 lg:w-1/5 flex justify-center">
                <a href="/index.html">
                    <img src="/images/Logo_Main.png" alt="The Intentional Tea Logo" class="h-8 md:h-12 w-auto object-contain">
                </a>
            </div>
            <div class="w-1/3 lg:w-2/5 flex justify-end space-x-6 items-center">
                <a href="https://gumroad.com/cart" class="gumroad-scroll flex items-center space-x-2 group" aria-label="Cart">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-rose transition-colors" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    <span class="header-link">Cart</span>
                </a>
            </div>
        </div>
        <nav id="mobile-nav" class="lg:hidden items-center space-y-4 pb-6 border-t border-black/5 pt-4 bg-[#FAF7F2]" aria-label="Mobile navigation">
            <a href="/index.html" class="header-link">Home</a>
            <a href="/shop.html" class="header-link">Shop</a>
            <a href="/book.html" class="header-link">Work With Me</a>
            <a href="/about.html" class="header-link">About</a>
            <a href="/blog.html" class="header-link text-rose">Blog</a>
            <a href="/social.html" class="header-link">Links</a>
        </nav>
    </header>

    <section class="bg-[#1a1a1a] py-20 px-6 text-center space-y-4">
        <h1 class="playfair text-5xl md:text-6xl text-white">The Blog</h1>
        <p class="text-[10px] uppercase tracking-[0.5em] text-white/50">Perspective. Strategy. Intention.</p>
    </section>

    <main id="main-content" class="max-w-5xl mx-auto pt-16 pb-24 px-6">

        {% set posts = collections.posts | reverse %}
        {% if posts.length > 0 %}

        <div class="space-y-12">
            <div class="flex items-center justify-between border-b border-black/10 pb-4">
                <h2 class="text-sm uppercase tracking-[0.3em] font-bold text-[#1a1a1a]">Latest Posts</h2>
                <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-[#1a1a1a]/40">{{ posts.length }} post{% if posts.length != 1 %}s{% endif %}</span>
            </div>

            <div class="grid md:grid-cols-2 gap-14">
                {% for post in posts %}
                <article>
                    <a href="{{ post.url }}" class="group space-y-5 block">
                        <div class="space-y-3">
                            {% if post.data.category %}
                            <span class="text-[9px] uppercase tracking-widest font-bold" style="color:#C99B92;">{{ post.data.category }}</span>
                            {% endif %}
                            <h3 class="text-2xl serif italic leading-snug group-hover:text-rose transition-colors">{{ post.data.title }}</h3>
                            {% if post.data.description %}
                            <p class="text-sm text-[#2a2a2a] font-light leading-relaxed">{{ post.data.description }}</p>
                            {% endif %}
                        </div>
                        <div class="flex items-center justify-between border-t border-black/5 pt-4">
                            <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-[#1a1a1a]/40">{{ post.data.date | postDate }}</span>
                            <span class="text-[10px] uppercase tracking-widest font-bold border-b border-black group-hover:text-rose group-hover:border-rose transition-colors">Read &rarr;</span>
                        </div>
                    </a>
                </article>
                {% endfor %}
            </div>
        </div>

        {% else %}

        <div class="text-center py-24 space-y-6">
            <p class="text-[10px] uppercase tracking-[0.4em] font-bold" style="color:#C99B92;">Coming Soon</p>
            <h2 class="serif italic text-3xl">The first post is on its way.</h2>
            <p class="text-sm text-[#2a2a2a] font-light">In the meantime, explore the shop or learn more about the brand.</p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
                <a href="/shop.html" class="header-link border-b border-black/20 pb-1 hover:text-[#C99B92] hover:border-[#C99B92] transition-colors">Shop the Collection</a>
                <a href="/about.html" class="header-link border-b border-black/20 pb-1 hover:text-[#C99B92] hover:border-[#C99B92] transition-colors">About the Brand</a>
            </div>
        </div>

        {% endif %}

    </main>

    <footer class="bg-[#FAF7F2] py-4 px-6 border-t border-black/5" role="contentinfo">
        <div class="max-w-sm mx-auto flex flex-col items-center gap-3 text-[8px] uppercase tracking-[0.3em] text-[#1a1a1a]/60">
            <span class="text-[#1a1a1a]/70 font-semibold">&copy; 2026 The Intentional Tea</span>
            <div class="flex gap-6">
                <button onclick="openModal('terms')" class="hover:text-black transition-colors">Terms</button>
                <button onclick="openModal('refund')" class="hover:text-black transition-colors">Refunds</button>
                <button onclick="openModal('privacy')" class="hover:text-black transition-colors">Privacy</button>
                <button onclick="openModal('disclaimer')" class="hover:text-black transition-colors">Disclaimers</button>
            </div>
        </div>
    </footer>

    <div id="policy-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-6 bg-black/40 backdrop-blur-sm" onclick="closeModal()">
        <div class="bg-white max-w-2xl w-full max-h-[80vh] overflow-y-auto p-12 relative shadow-2xl" onclick="event.stopPropagation()">
            <button onclick="closeModal()" class="absolute top-6 right-6 text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 hover:text-black" aria-label="Close modal">Close [x]</button>
            <div id="modal-content"></div>
        </div>
    </div>

    <script>
        function toggleMenu() {
            const nav = document.getElementById('mobile-nav');
            nav.classList.toggle('active');
        }

        const policyContent = {
            terms: `<h2 class="playfair text-3xl mb-6">Terms &amp; Conditions</h2><p class="text-sm leading-relaxed text-[#2a2a2a]">Standard terms for digital licensing. Products are for personal use only.</p>`,
            refund: `<h2 class="playfair text-3xl mb-6">Refund Policy</h2><p class="text-sm leading-relaxed text-[#2a2a2a]">Due to the nature of digital products, all sales of The Intentional Tea products are final.</p>`,
            privacy: `<h2 class="playfair text-3xl mb-6">Privacy Policy</h2><p class="text-sm leading-relaxed text-[#2a2a2a]">We value your privacy. Your data is only used to fulfill orders and send newsletter updates.</p>`,
            disclaimer: `<h2 class="playfair text-3xl mb-6">Disclaimers</h2><p class="text-sm leading-relaxed text-[#2a2a2a]">The content on this blog is for informational and educational purposes only and does not constitute professional advice.</p>`
        };

        function openModal(type) {
            const modal = document.getElementById('policy-modal');
            document.getElementById('modal-content').innerHTML = policyContent[type];
            modal.style.display = 'flex';
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            const modal = document.getElementById('policy-modal');
            modal.style.display = 'none';
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
    </script>
</body>
</html>
